// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  STAFF
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          UserRole  @default(OWNER)
  shopId        String?   @map("shop_id")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  shop     Shop?     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  staffProfile StaffProfile?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  ownerId   String   @map("owner_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  products Product[]
  sales    Sale[]
  settings ShopSettings?

  @@map("shops")
}

model Product {
  id           String   @id @default(cuid())
  shopId       String   @map("shop_id")
  name         String
  buyingPrice  Float    @default(0) @map("buying_price")
  sellingPrice Float    @default(0) @map("selling_price")
  discount     Float    @default(0)
  stock        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  saleItems SaleItem[]
  shop      Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, name])
  @@map("products")
}

model Sale {
  id            String   @id @default(cuid())
  shopId        String   @map("shop_id")
  totalAmount   Float    @map("total_amount")
  totalProfit   Float    @map("total_profit")
  totalDiscount Float    @map("total_discount")
  createdAt     DateTime @default(now())

  items SaleItem[]
  shop  Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@map("sales")
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String  @map("sale_id")
  productId    String? @map("product_id")
  productName  String  @map("product_name")
  quantity     Int
  buyingPrice  Float   @map("buying_price")
  sellingPrice Float   @map("selling_price")
  discount     Float
  finalPrice   Float   @map("final_price")
  profit       Float
  lineTotal    Float   @default(0) @map("line_total")

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@map("sale_items")
}

model ShopSettings {
  id             String   @id @default(cuid())
  shopId         String   @unique @map("shop_id")
  shopName       String   @default("My Shop") @map("shop_name")
  address        String   @default("")
  phone          String   @default("")
  gstNumber      String   @default("") @map("gst_number")
  email          String   @default("")
  currencySymbol String   @default("₹") @map("currency_symbol")
  updatedAt      DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@map("shop_settings")
}

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  phone           String   @default("")
  salary          Float    @default(0)
  performancePoints Int    @default(0) @map("performance_points")
  joiningDate     DateTime @default(now()) @map("joining_date")
  notes           String   @default("")
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  increments      SalaryIncrement[]

  @@map("staff_profiles")
}

model SalaryIncrement {
  id              String   @id @default(cuid())
  staffProfileId  String   @map("staff_profile_id")
  amount          Float
  reason          String   @default("")
  createdAt       DateTime @default(now())

  staffProfile    StaffProfile @relation(fields: [staffProfileId], references: [id], onDelete: Cascade)

  @@map("salary_increments")
}
